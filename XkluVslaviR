UserInputService.InputBegan:Connect(function(input, processed)
    -- GUI toggle (never blocked)
    if input.KeyCode == CONFIG.GUI_TOGGLE_KEY then
        gui:Toggle()
        return
    end
    if processed then return end

    -- ── AIMBOT ──
    if CONFIG.ENABLED then
        local isAimbotKey = (input.KeyCode == CONFIG.KEYBIND) or (input.UserInputType == CONFIG.KEYBIND)
        if isAimbotKey then
            if CONFIG.ACTIVATION_MODE == "Hold" then
                STATE.active = true
                STATE.holding_key = true
            elseif CONFIG.ACTIVATION_MODE == "Toggle" then
                STATE.active = not STATE.active
                STATE.holding_key = STATE.active
                if not STATE.active then clearTarget() end
            end
        end
    end

    -- ── FLY (Toggle mode only — Hold/Always handled in UpdateFlyMode) ──
    if FLY_CONFIG.ENABLED and FLY_CONFIG.ACTIVATION_MODE == "Toggle" then
        local isFlyKey = (input.KeyCode == FLY_CONFIG.KEYBIND) or (input.UserInputType == FLY_CONFIG.KEYBIND)
        if isFlyKey then
            ToggleFly()
        end
    end

    -- ── TRIGGERBOT ──
    if TRIGGER_CONFIG.ENABLED then
        local isTriggerKey = (input.KeyCode == TRIGGER_CONFIG.KEYBIND) or (input.UserInputType == TRIGGER_CONFIG.KEYBIND)
        if isTriggerKey then
            if TRIGGER_CONFIG.MODE == "Hold" then
                TRIGGER_STATE.active = true
            elseif TRIGGER_CONFIG.MODE == "Toggle" then
                TRIGGER_STATE.toggled = not TRIGGER_STATE.toggled
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, processed)
    if processed then return end

    -- ── AIMBOT Hold release ──
    if CONFIG.ACTIVATION_MODE == "Hold" then
        local isAimbotKey = (input.KeyCode == CONFIG.KEYBIND) or (input.UserInputType == CONFIG.KEYBIND)
        if isAimbotKey then
            STATE.active = false
            STATE.holding_key = false
            clearTarget()
        end
    end

    -- ── TRIGGERBOT Hold release ──
    if TRIGGER_CONFIG.MODE == "Hold" then
        local isTriggerKey = (input.KeyCode == TRIGGER_CONFIG.KEYBIND) or (input.UserInputType == TRIGGER_CONFIG.KEYBIND)
        if isTriggerKey then
            TRIGGER_STATE.active = false
        end
    end
end)

