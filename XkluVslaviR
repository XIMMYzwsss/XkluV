    -- Swapped: opaque black at start (top) fading to transparent at end (bottom)
    -- because -90 rotation means start=bottom, end=top, so swap to get dark at bottom
    svDarkGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),  -- opaque black at start
        NumberSequenceKeypoint.new(1, 1),  -- transparent at end
    })
    svDarkGrad.Rotation = -90
    svDarkGrad.Parent = svDarkLayer

    -- SV cursor sits above both layers
    local svCursor = Instance.new("Frame")
    svCursor.Size = UDim2.new(0, 10, 0, 10)
    svCursor.AnchorPoint = Vector2.new(0.5, 0.5)
    svCursor.BackgroundColor3 = Color3.new(1, 1, 1)
