    hueBar.ZIndex = 302
    hueBar.Parent = popup
    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,     1, 1)),
        ColorSequenceKeypoint.new(0.167,Color3.fromHSV(0.167, 1, 1)),
        ColorSequenceKeypoint.new(0.333,Color3.fromHSV(0.333, 1, 1)),
        ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5,   1, 1)),
        ColorSequenceKeypoint.new(0.667,Color3.fromHSV(0.667, 1, 1)),
        ColorSequenceKeypoint.new(0.833,Color3.fromHSV(0.833, 1, 1)),
        ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,     1, 1)),
    })
    hueGrad.Parent = hueBar
    local hueBarCorner = Instance.new("UICorner")
    hueBarCorner.CornerRadius = UDim.new(0, 4)
    hueBarCorner.Parent = hueBar

    -- Hue cursor
    local hueCursor = Instance.new("Frame")
    hueCursor.Size = UDim2.new(0, 6, 1, 4)
    hueCursor.AnchorPoint = Vector2.new(0.5, 0.5)
    hueCursor.BackgroundColor3 = Color3.new(1, 1, 1)
    hueCursor.BorderSizePixel = 0
    hueCursor.ZIndex = 304
    hueCursor.Position = UDim2.new(h, 0, 0.5, 0)
    hueCursor.Parent = hueBar
    local hueCursorC = Instance.new("UICorner")
    hueCursorC.CornerRadius = UDim.new(0, 2)
    hueCursorC.Parent = hueCursor
    local hueCursorStroke = Instance.new("UIStroke")
    hueCursorStroke.Color = Color3.new(0, 0, 0)
    hueCursorStroke.Thickness = 1.5
    hueCursorStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    hueCursorStroke.Parent = hueCursor

    -- Preview swatch + hex
    local previewSwatch = Instance.new("Frame")
    previewSwatch.Size = UDim2.new(0, 36, 0, 28)
    previewSwatch.Position = UDim2.new(0, 20, 0, 212)
    previewSwatch.BackgroundColor3 = default
    previewSwatch.BorderSizePixel = 0
    previewSwatch.ZIndex = 302
    previewSwatch.Parent = popup
    local previewCorner = Instance.new("UICorner")
    previewCorner.CornerRadius = UDim.new(0, 5)
    previewCorner.Parent = previewSwatch

    local hexLabel = Instance.new("TextLabel")
    hexLabel.Size = UDim2.new(0, 148, 0, 28)
    hexLabel.Position = UDim2.new(0, 62, 0, 212)
    hexLabel.BackgroundTransparency = 1
    hexLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    hexLabel.TextSize = 11
    hexLabel.Font = Enum.Font.Code
    hexLabel.TextXAlignment = Enum.TextXAlignment.Left
    hexLabel.ZIndex = 302
    hexLabel.Parent = popup

    local function applyColor()
        currentColor = Color3.fromHSV(h, s, v2)
        colorButton.BackgroundColor3 = currentColor
        previewSwatch.BackgroundColor3 = currentColor
        svFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)  -- pure hue as base
        local r = math.floor(currentColor.R * 255)
        local g = math.floor(currentColor.G * 255)
        local b = math.floor(currentColor.B * 255)
        hexLabel.Text = string.format("#%02X%02X%02X  rgb(%d,%d,%d)", r, g, b, r, g, b)
        svCursor.Position = UDim2.fromScale(s, 1 - v2)
        hueCursor.Position = UDim2.new(h, 0, 0.5, 0)
        callback(currentColor)
    end
    applyColor()

    -- SV drag
    local svDragging = false
    svFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
        end
    end)
    svFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
        end
    end)

    -- Hue drag
    local hueDragging = false
    hueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
        end
    end)
    hueBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if not popup.Visible then return end
        local mp = input.Position

        if svDragging then
            local abs = svFrame.AbsolutePosition
            local sz  = svFrame.AbsoluteSize
            s  = math.clamp((mp.X - abs.X) / sz.X, 0, 1)
            v2 = 1 - math.clamp((mp.Y - abs.Y) / sz.Y, 0, 1)
            applyColor()
        end

        if hueDragging then
            local abs = hueBar.AbsolutePosition
            local sz  = hueBar.AbsoluteSize
            h = math.clamp((mp.X - abs.X) / sz.X, 0, 1)
            applyColor()
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging  = false
            hueDragging = false
        end
    end)

    -- Open picker on button click (close only via X button)
    colorButton.MouseButton1Click:Connect(function()
        if popup.Visible then return end
        local btnAbs = colorButton.AbsolutePosition
        local btnSz  = colorButton.AbsoluteSize
        local vp     = Camera.ViewportSize
        local pw, ph = 220, 255
        local px = math.clamp(btnAbs.X, 0, vp.X - pw)
        local py = btnAbs.Y + btnSz.Y + 4
        if py + ph > vp.Y then py = btnAbs.Y - ph - 4 end
        popup.Position = UDim2.fromOffset(px, py)
        popup.Visible = true
    end)

    return {
        SetValue = function(color)
            currentColor = color
            h, s, v2 = Color3.toHSV(color)
            colorButton.BackgroundColor3 = color
            applyColor()
        end
    }
end

