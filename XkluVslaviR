-- DEFLECT TRACKING
-- Scans workspace for any known katana deflect sound IDs.
-- Add new IDs to DEFLECT_SOUND_IDS as more katanas are discovered.
-- ══════════════════════════════════════════════════════

local DEFLECT_SOUND_IDS = {
    ["rbxassetid://14798337918"] = true, -- default katana
    -- ["rbxassetid://16736552001"] = true, -- pixel katana (wrong id, fix later)
}

local deflectState      = {} -- player -> bool
local deflectTimestamps = {} -- player -> tick() when deflect started
local DEFLECT_TIMEOUT   = 1.5

local function monitorSound(sound)
    if not sound:IsA("Sound") then return end
    if not DEFLECT_SOUND_IDS[sound.SoundId] then return end

    local function getOwner()
        local character = sound:FindFirstAncestorOfClass("Model")
        if not character then return nil end
        return Players:GetPlayerFromCharacter(character)
    end

    local function setDeflecting(state)
        local player = getOwner()
        if not player then return end
        deflectState[player] = state
        if state then
            deflectTimestamps[player] = tick()
        else
            deflectTimestamps[player] = nil
        end
    end

    -- Playing property: fires on both start AND stop (including mid-play cuts)
    sound:GetPropertyChangedSignal("Playing"):Connect(function()
        setDeflecting(sound.Playing)
    end)

    -- Ended: natural end of sound
    sound.Ended:Connect(function()
        setDeflecting(false)
    end)

    -- Stopped: explicit stop call
    sound.Stopped:Connect(function()
        setDeflecting(false)
    end)

    -- Sound removed from workspace mid-play (character died, reset, etc.)
    sound.AncestryChanged:Connect(function(_, parent)
        if not parent then
            setDeflecting(false)
        end
    end)

    -- Sync immediately
    setDeflecting(sound.Playing)
end

-- Scan all existing sounds in workspace
for _, v in pairs(Workspace:GetDescendants()) do
    monitorSound(v)
end

-- Watch for new sounds added to workspace (covers respawns and late-loaded sounds)
Workspace.DescendantAdded:Connect(function(v)
    monitorSound(v)
end)

local function IsDeflecting(player)
    return deflectState[player] == true
end

