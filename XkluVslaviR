    copyBtn.TextColor3 = Color3.new(1, 1, 1)
    copyBtn.TextSize = 12
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.BorderSizePixel = 0
    copyBtn.ZIndex = 5
    copyBtn.Parent = holder

    local copyCorner = Instance.new("UICorner")
    copyCorner.CornerRadius = UDim.new(0, 5)
    copyCorner.Parent = copyBtn

    copyBtn.MouseButton1Click:Connect(function()
        local text = "Name: " .. sound.Name .. "\nID: " .. id .. "\nPath: " .. path
        if setclipboard then setclipboard(text) end
        copyBtn.Text = "ok"
        task.delay(1.5, function() copyBtn.Text = "Copy" end)
    end)

    -- Force canvas resize immediately so scroll works right away
    task.defer(sfUpdateCanvas)
end

local function sfMonitor(sound)
    if not sound:IsA("Sound") then return end
    sound:GetPropertyChangedSignal("Playing"):Connect(function()
        if sound.Playing then
            sfCreateEntry(sound)
        end
    end)
end

