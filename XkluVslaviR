-- ══════════════════════════════════════════════════════
-- ESP BOUNDS CACHE
-- Bounds are computed cheaply from a handful of key parts (not 8 corners × N parts)
-- and throttled to every BOUNDS_THROTTLE frames so we don't burn CPU every frame.
-- ══════════════════════════════════════════════════════

local partCache = {} -- player -> { keyParts={head,torso,lleg,rleg,larm,rarm}, char, bounds, tick }
local BOUNDS_THROTTLE = 4 -- recompute every 4 frames (~15fps for box position, imperceptible)

local KEY_PART_NAMES = {
    "Head","Torso","UpperTorso","LowerTorso",
    "Left Arm","Right Arm","LeftUpperArm","RightUpperArm",
    "Left Leg","Right Leg","LeftUpperLeg","RightUpperLeg","LeftFoot","RightFoot",
}

local function BuildKeyParts(char)
    local parts = {}
    for _, name in ipairs(KEY_PART_NAMES) do
        local p = char:FindFirstChild(name)
        if p then parts[#parts+1] = p end
    end
    -- fallback: if somehow nothing matched, grab all non-HRP baseparts
    if #parts == 0 then
        for _, p in ipairs(char:GetChildren()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                parts[#parts+1] = p
            end
        end
    end
    return parts
end

local function ClearPartCache(player)
    partCache[player] = nil
end

-- Compute screen-space bounding box using 1 projection per part + depth-based radius.
-- Depth formula: screenPixels ≈ (worldUnits * focalLength) / depth
-- This is ~3x cheaper than projecting 3 points per part.
local function ComputeBoundsLight(keyParts)
    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    local any = false
    local vp = Camera.ViewportSize
    -- Roblox vertical FOV -> focal length in pixels
    local fov = math.rad(Camera.FieldOfView)
    local focalLen = (vp.Y * 0.5) / math.tan(fov * 0.5)

    for _, p in ipairs(keyParts) do
        if p and p.Parent then
            local sp, on, depth = W2V(p.Position)
            if on and depth > 0.5 then
                any = true
                -- Approximate half-extent in screen pixels from world size and depth
                local sz = p.Size
                local halfWorld = math.max(sz.X, sz.Y, sz.Z) * 0.5
                local r = math.max(4, (halfWorld * focalLen) / depth)
                if sp.X - r < minX then minX = sp.X - r end
                if sp.Y - r < minY then minY = sp.Y - r end
                if sp.X + r > maxX then maxX = sp.X + r end
                if sp.Y + r > maxY then maxY = sp.Y + r end
            end
        end
    end
    if not any then return nil end
    local pd = 2
    return {
        minX=minX-pd, minY=minY-pd,
        maxX=maxX+pd, maxY=maxY+pd,
        cx=(minX+maxX)*0.5, cy=(minY+maxY)*0.5,
    }
end

local function GetBoundsCached(player, char)
    local cache = partCache[player]
    if not cache or cache.char ~= char then
        partCache[player] = { keyParts=BuildKeyParts(char), char=char, bounds=nil, frame=0 }
        cache = partCache[player]
    end
    -- stagger updates: each player recomputes on a different frame
    local playerFrame = (cache.frame or 0) + 1
    cache.frame = playerFrame
    if playerFrame >= BOUNDS_THROTTLE or not cache.bounds then
        cache.frame = 0
        cache.bounds = ComputeBoundsLight(cache.keyParts)
    end
    return cache.bounds
end


local function IsFacingLocalPlayer(char)
    local lc = localPlayer.Character
    if not lc then return false end
    local lr = GetRoot(lc)
    local tr = GetRoot(char)
    if not lr or not tr then return false end
    local d = lr.Position - tr.Position
    local flat = Vector3.new(d.X, 0, d.Z)
    if flat.Magnitude < 0.1 then return false end
    flat = flat.Unit
    local lv = tr.CFrame.LookVector
    local lf = Vector3.new(lv.X, 0, lv.Z)
    if lf.Magnitude < 0.1 then return false end
    return lf.Unit:Dot(flat) > 0.75
end

local function PlaceLabel(side, bounds, cursor, fontSize)
    local pos, anchor

    if side == "Above" then
        local y = bounds.minY - cursor.Above
        cursor.Above = cursor.Above + fontSize + GAP
        pos = Vector2.new(bounds.cx, y)
        anchor = Vector2.new(0.5, 1.0)
    elseif side == "Below" then
        local y = bounds.maxY + cursor.Below
        cursor.Below = cursor.Below + fontSize + GAP
        pos = Vector2.new(bounds.cx, y)
        anchor = Vector2.new(0.5, 0.0)
    elseif side == "Left" then
        local y = bounds.cy + cursor.LeftN * (fontSize + GAP)
        cursor.LeftN = cursor.LeftN + 1
        pos = Vector2.new(bounds.minX - SIDE_GAP, y)
        anchor = Vector2.new(1.0, 0.5)
    elseif side == "Right" then
        local y = bounds.cy + cursor.RightN * (fontSize + GAP)
        cursor.RightN = cursor.RightN + 1
        pos = Vector2.new(bounds.maxX + SIDE_GAP, y)
        anchor = Vector2.new(0.0, 0.5)
    end

    return pos, anchor
end

local function SetLabelPos(lbl, pos, anchor)
    lbl.AnchorPoint = anchor
    lbl.Position = UDim2.fromOffset(pos.X, pos.Y)
    lbl.Size = UDim2.fromOffset(400, lbl.TextSize + 2)
    if anchor.X == 0.5 then
        lbl.TextXAlignment = Enum.TextXAlignment.Center
    elseif anchor.X == 1.0 then
        lbl.TextXAlignment = Enum.TextXAlignment.Right
    else
        lbl.TextXAlignment = Enum.TextXAlignment.Left
    end
end

local function UpdateHeadCircle(lines, head, visible, color, thickness)
    if not visible or not head then
        for _, l in ipairs(lines) do l.Visible = false end
        return
    end
    local headSP, onSc, depth = W2V(head.Position)
    if not onSc or depth < 0 then
        for _, l in ipairs(lines) do l.Visible = false end
        return
    end
    local edgeSP = W2V(head.Position + Camera.CFrame.RightVector * 0.65)
    local radius = (edgeSP - headSP).Magnitude * HEAD_CIRCLE_SCALE
    for i = 1, CIRCLE_SEGS do
        local a0 = (i - 1) / CIRCLE_SEGS * math.pi * 2
        local a1 = i / CIRCLE_SEGS * math.pi * 2
        local ln = lines[i]
        ln.From = Vector2.new(headSP.X + math.cos(a0)*radius, headSP.Y + math.sin(a0)*radius)
        ln.To   = Vector2.new(headSP.X + math.cos(a1)*radius, headSP.Y + math.sin(a1)*radius)
        ln.Color = color
        ln.Thickness = thickness
        ln.Visible = true
    end
end

local function UpdateHeadCircleOutline(lines, head, visible, thickness)
    if not visible or not head then
        for _, l in ipairs(lines) do l.Visible = false end
        return
    end
    local headSP, onSc, depth = W2V(head.Position)
    if not onSc or depth < 0 then
        for _, l in ipairs(lines) do l.Visible = false end
        return
    end
    local edgeSP = W2V(head.Position + Camera.CFrame.RightVector * 0.65)
    local radius = (edgeSP - headSP).Magnitude * HEAD_CIRCLE_SCALE
    for i = 1, CIRCLE_SEGS do
        local a0 = (i - 1) / CIRCLE_SEGS * math.pi * 2
        local a1 = i / CIRCLE_SEGS * math.pi * 2
        local ln = lines[i]
        ln.From = Vector2.new(headSP.X + math.cos(a0)*radius, headSP.Y + math.sin(a0)*radius)
        ln.To   = Vector2.new(headSP.X + math.cos(a1)*radius, headSP.Y + math.sin(a1)*radius)
        ln.Color = BLACK
        ln.Thickness = thickness + 2
        ln.Visible = true
    end
end

