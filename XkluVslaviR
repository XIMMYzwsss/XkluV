-- GUI THEME
-- Two colors drive the entire UI. Change them live via
-- the Settings tab color pickers.
-- ══════════════════════════════════════════════════════

local THEME = {
    Accent    = Color3.fromRGB(100, 70, 180),   -- borders, active tabs, buttons
    Highlight = Color3.fromRGB(160, 110, 255),  -- titles, labels, version text
    Active    = Color3.fromRGB(160, 110, 255),  -- toggle ON, slider fill, value text (always mirrors Highlight)
}

-- Registry of themed elements updated when colors change
local _themedAccent    = {}
local _themedHighlight = {}
local _themedActive    = {} -- slider fill, value text
local _themedToggles   = {} -- { toggle=btn, getEnabled=fn } — updated live on applyTheme

local function registerAccent(obj, prop)
    table.insert(_themedAccent, { obj = obj, prop = prop })
    obj[prop] = THEME.Accent
end

local function registerHighlight(obj, prop)
    table.insert(_themedHighlight, { obj = obj, prop = prop })
    obj[prop] = THEME.Highlight
end

local function registerActive(obj, prop)
    table.insert(_themedActive, { obj = obj, prop = prop })
    obj[prop] = THEME.Active
end

local function registerToggle(toggleBtn, getEnabled)
    table.insert(_themedToggles, { btn = toggleBtn, getEnabled = getEnabled })
end

local function applyTheme()
    for _, e in ipairs(_themedAccent) do
        if e.obj and e.obj.Parent then e.obj[e.prop] = THEME.Accent end
    end
    for _, e in ipairs(_themedHighlight) do
        if e.obj and e.obj.Parent then e.obj[e.prop] = THEME.Highlight end
    end
    for _, e in ipairs(_themedActive) do
        if e.obj and e.obj.Parent then e.obj[e.prop] = THEME.Active end
    end
    -- Update toggles based on their current enabled state
    for _, t in ipairs(_themedToggles) do
        if t.btn and t.btn.Parent then
            t.btn.BackgroundColor3 = t.getEnabled() and THEME.Active or Color3.fromRGB(40, 40, 50)
        end
    end
end

