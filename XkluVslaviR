-- ESP RENDER LOOP
-- Runs every frame. Bounds are recomputed only when the
-- player's root has moved > 0.5 studs since last compute,
-- so stationary/slow players cost almost nothing.
-- Alive check uses a cached Humanoid ref — no FindFirst every frame.
-- ══════════════════════════════════════════════════════

-- ══════════════════════════════════════════════════════
-- ESP RENDER LOOP — simple and reliable, every frame
-- ══════════════════════════════════════════════════════

RunService.RenderStepped:Connect(function()
    if not ESP_CONFIG.Master.Enabled then
        for _, esp in pairs(ESPObjects) do HideAllESP(esp) end
        return
    end

    local lc    = localPlayer.Character
    local lroot = lc and lc:FindFirstChild("HumanoidRootPart")

    for player, esp in pairs(ESPObjects) do

        -- Self check
        if player == localPlayer then
            HideAllESP(esp); continue
        end

        -- Team check
        if player ~= localPlayer and ESP_CONFIG.TeamCheck.Enabled then
            local mine   = localPlayer:GetAttribute("TeamID")
            local theirs = player:GetAttribute("TeamID")
            if mine and theirs and mine == theirs then
                HideAllESP(esp); continue
            end
        end

        local char = player.Character
        if not char then HideAllESP(esp); continue end

        -- Alive check
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then HideAllESP(esp); continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not root or not head then HideAllESP(esp); continue end

        -- On screen + distance
        local rootSP, rootOn, rootZ = W2V(root.Position)
        if not rootOn or rootZ < 0 then HideAllESP(esp); continue end

        local dist = lroot and math.floor((root.Position - lroot.Position).Magnitude) or 0
        if dist > 1300 then HideAllESP(esp); continue end

        -- ── BOUNDS ───────────────────────────────────────────
        -- Simple 2-point bounds: head top and foot bottom, width from root depth
        local headSP, headOn = W2V(head.Position + Vector3.new(0, head.Size.Y * 0.6, 0))
        if not headOn then HideAllESP(esp); continue end

        -- Find lowest visible part for the bottom of the box
        local footPart = char:FindFirstChild("HumanoidRootPart")
        local lowestY = rootSP.Y
        for _, partName in ipairs({"Left Leg","Right Leg","LeftFoot","RightFoot","LowerTorso"}) do
            local p = char:FindFirstChild(partName)
            if p then
                local psp, pon = W2V(p.Position - Vector3.new(0, p.Size.Y * 0.5, 0))
                if pon and psp.Y > lowestY then lowestY = psp.Y end
            end
        end

        local boxH = lowestY - headSP.Y
        if boxH < 5 then HideAllESP(esp); continue end
        local boxW = boxH * 0.45

        local bounds = {
            minX = rootSP.X - boxW,
            maxX = rootSP.X + boxW,
            minY = headSP.Y,
            maxY = lowestY,
            cx   = rootSP.X,
            cy   = (headSP.Y + lowestY) * 0.5,
        }

        -- ── BOX ESP ───────────────────────────────────────────
        local boxOn   = ESP_CONFIG.BoxESP.Enabled
        local boxOlOn = boxOn and ESP_CONFIG.BoxESP.Outline
        local btype   = ESP_CONFIG.BoxESP.BoxType
        local bcol    = ESP_CONFIG.BoxESP.Color
        local bthk    = ESP_CONFIG.BoxESP.Thickness

        local function SetBoxLine(idx, from, to)
            if boxOlOn then
                local ol=esp.BoxOutlines[idx]; ol.From=from; ol.To=to
                ol.Thickness=bthk+2; ol.Visible=true
            else esp.BoxOutlines[idx].Visible=false end
            local ln=esp.BoxLines[idx]; ln.From=from; ln.To=to
            ln.Color=bcol; ln.Thickness=bthk; ln.Visible=true
        end
        local function HideBoxLine(idx)
            esp.BoxLines[idx].Visible=false; esp.BoxOutlines[idx].Visible=false
        end

        if not boxOn then
            for i=1,8 do HideBoxLine(i) end
        elseif btype=="Normal" then
            local tl=Vector2.new(bounds.minX,bounds.minY); local tr=Vector2.new(bounds.maxX,bounds.minY)
            local bl=Vector2.new(bounds.minX,bounds.maxY); local br=Vector2.new(bounds.maxX,bounds.maxY)
            SetBoxLine(1,tl,tr); SetBoxLine(2,tr,br); SetBoxLine(3,br,bl); SetBoxLine(4,bl,tl)
            for i=5,8 do HideBoxLine(i) end
        elseif btype=="Corner" then
            local w=bounds.maxX-bounds.minX; local h=bounds.maxY-bounds.minY
            local cw=w*0.25; local ch=h*0.25
            local x0,x1=bounds.minX,bounds.maxX; local y0,y1=bounds.minY,bounds.maxY
            SetBoxLine(1,Vector2.new(x0,y0),Vector2.new(x0+cw,y0))
            SetBoxLine(2,Vector2.new(x0,y0),Vector2.new(x0,y0+ch))
            SetBoxLine(3,Vector2.new(x1,y0),Vector2.new(x1-cw,y0))
            SetBoxLine(4,Vector2.new(x1,y0),Vector2.new(x1,y0+ch))
            SetBoxLine(5,Vector2.new(x0,y1),Vector2.new(x0+cw,y1))
            SetBoxLine(6,Vector2.new(x0,y1),Vector2.new(x0,y1-ch))
            SetBoxLine(7,Vector2.new(x1,y1),Vector2.new(x1-cw,y1))
            SetBoxLine(8,Vector2.new(x1,y1),Vector2.new(x1,y1-ch))
        end

        -- ── LABELS ────────────────────────────────────────────
        local function ScaleSize(base)
            return math.max(6, base - (rootZ - 10) * 0.1)
        end
        local cursor = { Above=GAP, Below=GAP, LeftN=0, RightN=0 }

        if ESP_CONFIG.NameESP.Enabled then
            local mode=ESP_CONFIG.NameESP.NameMode
            local txt = (mode=="Username") and player.Name
                     or (mode=="Both") and (player.DisplayName.." (@"..player.Name..")")
                     or player.DisplayName
            local lbl=esp.NameLabel; local sz=ScaleSize(ESP_CONFIG.NameESP.Size)
            local pos,anch=PlaceLabel(ESP_CONFIG.NameESP.Position,bounds,cursor,sz)
            lbl.Text=txt; lbl.TextColor3=ESP_CONFIG.NameESP.Color; lbl.TextSize=sz
            lbl.TextStrokeTransparency=ESP_CONFIG.NameESP.Outline and 0.4 or 1
            SetLabelPos(lbl,pos,anch); lbl.Visible=true
        else esp.NameLabel.Visible=false end

        if ESP_CONFIG.DistanceESP.Enabled then
            local lbl=esp.DistLabel; local sz=ScaleSize(ESP_CONFIG.DistanceESP.Size)
            local pos,anch=PlaceLabel(ESP_CONFIG.DistanceESP.Position,bounds,cursor,sz)
            lbl.Text=dist.." studs"; lbl.TextColor3=ESP_CONFIG.DistanceESP.Color; lbl.TextSize=sz
            lbl.TextStrokeTransparency=ESP_CONFIG.DistanceESP.Outline and 0.4 or 1
            SetLabelPos(lbl,pos,anch); lbl.Visible=true
        else esp.DistLabel.Visible=false end

        if ESP_CONFIG.FacingESP.Enabled and IsFacingLocalPlayer(char) then
            local lbl=esp.FacingLabel; local sz=ScaleSize(ESP_CONFIG.FacingESP.Size)
            local pos,anch=PlaceLabel(ESP_CONFIG.FacingESP.Position,bounds,cursor,sz)
            lbl.Text="[facing]"; lbl.TextColor3=ESP_CONFIG.FacingESP.Color; lbl.TextSize=sz
            lbl.TextStrokeTransparency=ESP_CONFIG.FacingESP.Outline and 0.4 or 1
            SetLabelPos(lbl,pos,anch); lbl.Visible=true
        else esp.FacingLabel.Visible=false end

        -- DEFLECT
        if ESP_CONFIG.DeflectESP.Enabled and IsDeflecting(player) then
            local lbl=esp.DeflectLabel; local sz=ScaleSize(ESP_CONFIG.DeflectESP.Size)
            local pos,anch=PlaceLabel(ESP_CONFIG.DeflectESP.Position,bounds,cursor,sz)
            lbl.Text="[DEFLECTING]"; lbl.TextColor3=ESP_CONFIG.DeflectESP.Color; lbl.TextSize=sz
            lbl.TextStrokeTransparency=ESP_CONFIG.DeflectESP.Outline and 0.4 or 1
            SetLabelPos(lbl,pos,anch); lbl.Visible=true
        else esp.DeflectLabel.Visible=false end

        -- ── SKELETON ─────────────────────────────────────────
        local skelOn  = ESP_CONFIG.SkeletonESP.Enabled
        local skelOl  = skelOn and ESP_CONFIG.SkeletonESP.Outline
        local skelCol = ESP_CONFIG.SkeletonESP.Color
        local skelThk = ESP_CONFIG.SkeletonESP.Thickness
        local isR6    = char:FindFirstChild("Torso") ~= nil
        local bones   = isR6 and R6_BONES or R15_BONES

        if skelOn then
            local sidx = 1
            for _, pair in ipairs(bones) do
                local p0 = char:FindFirstChild(pair[1])
                local p1 = char:FindFirstChild(pair[2])
                local ln  = esp.SkeletonLines[sidx]
                local olo = esp.SkeletonOutlines[sidx]
                if p0 and p1 then
                    local sp0, on0 = W2V(p0.Position)
                    local sp1, on1 = W2V(p1.Position)
                    if on0 and on1 then
                        if skelOl then
                            olo.From=sp0; olo.To=sp1; olo.Thickness=skelThk+2; olo.Visible=true
                        else olo.Visible=false end
                        ln.From=sp0; ln.To=sp1; ln.Color=skelCol; ln.Thickness=skelThk; ln.Visible=true
                        sidx=sidx+1; continue
                    end
                end
                ln.Visible=false; olo.Visible=false; sidx=sidx+1
            end
            for i=sidx,#esp.SkeletonLines do
                esp.SkeletonLines[i].Visible=false; esp.SkeletonOutlines[i].Visible=false
            end
        else
            for i=1,#esp.SkeletonLines do
                esp.SkeletonLines[i].Visible=false; esp.SkeletonOutlines[i].Visible=false
            end
        end

        -- ── HEAD CIRCLE ──────────────────────────────────────
        local hcOn = skelOn and ESP_CONFIG.SkeletonESP.HeadCircle
        UpdateHeadCircleOutline(esp.HeadCircleOutline, head, hcOn and skelOl, skelThk)
        UpdateHeadCircle(esp.HeadCircle, head, hcOn, skelCol, skelThk)


    end
end)

