-- TRIGGERBOT
-- Fires MB1 rapidly when the crosshair is over a valid target
-- ══════════════════════════════════════════════════════

local VIM = game:GetService("VirtualInputManager")

local function triggerIsTargetValid(player)
    if not player or player == localPlayer then return false end
    if not player.Character then return false end
    -- Team check
    if TRIGGER_CONFIG.TEAM_CHECK then
        local mine   = localPlayer:GetAttribute("TeamID")
        local theirs = player:GetAttribute("TeamID")
        if mine and theirs and mine == theirs then return false end
    end
    -- Anti katana
    if TRIGGER_CONFIG.ANTI_KATANA and IsDeflecting(player) then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function getTargetPartNames()
    local part = TRIGGER_CONFIG.TARGET_PART
    if part == "Head"  then return {"Head"} end
    if part == "Torso" then return {"Torso","UpperTorso","LowerTorso"} end
    -- "All" — shoot at any body part
    return {"Head","Torso","UpperTorso","LowerTorso",
            "Left Arm","Right Arm","LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm","LeftHand","RightHand",
            "Left Leg","Right Leg","LeftUpperLeg","RightUpperLeg","LeftLowerLeg","RightLowerLeg","LeftFoot","RightFoot"}
end

local function triggerFindTarget()
    -- Raycast from camera centre to find what we're looking at
    local cam = Camera
    local viewportSize = cam.ViewportSize
    local ray = cam:ViewportPointToRay(viewportSize.X/2, viewportSize.Y/2)
    local origin = ray.Origin
    local direction = ray.Direction * 2000

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    if localPlayer.Character then
        for _, p in ipairs(localPlayer.Character:GetDescendants()) do
            if p:IsA("BasePart") then ignore[#ignore+1] = p end
        end
    end
    params.FilterDescendantsInstances = ignore

    -- Wall check via raycast
    local result = Workspace:Raycast(origin, direction, params)
    if not result or not result.Instance then return nil end

    -- Walk up to find a player character
    local inst = result.Instance
    local char = inst:FindFirstAncestorOfClass("Model")
    if not char then return nil end
    local hitPlayer = Players:GetPlayerFromCharacter(char)
    if not hitPlayer or not triggerIsTargetValid(hitPlayer) then return nil end

    -- Check hit part is a valid target part
    if TRIGGER_CONFIG.TARGET_PART ~= "All" then
        local validNames = getTargetPartNames()
        local found = false
        for _, n in ipairs(validNames) do
            if inst.Name == n then found = true; break end
        end
        if not found then return nil end
    end

    -- Wall check option
    if TRIGGER_CONFIG.WALL_CHECK then
        local headPos = char:FindFirstChild("Head") and char.Head.Position
        if headPos then
            local wParams = RaycastParams.new()
            wParams.FilterType = Enum.RaycastFilterType.Exclude
            local wIgnore = {char}
            if localPlayer.Character then wIgnore[#wIgnore+1] = localPlayer.Character end
            wParams.FilterDescendantsInstances = wIgnore
            local wResult = Workspace:Raycast(origin, (headPos-origin), wParams)
            if wResult then return nil end -- blocked
        end
    end

    return hitPlayer
end

local _lastShot = 0
local function triggerShoot()
    local now = tick()
    local delay = TRIGGER_CONFIG.SHOOT_DELAY / 1000
    if (now - _lastShot) < delay then return end
    _lastShot = now
    VIM:SendMouseButtonEvent(0, 0, 0, true,  game, 1) -- MB1 down
    task.defer(function()
        VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1) -- MB1 up
    end)
end

local function triggerActive()
    if not TRIGGER_CONFIG.ENABLED then return false end
    local mode = TRIGGER_CONFIG.MODE
    if mode == "Always" then return true end
    if mode == "Toggle" then return TRIGGER_STATE.toggled end
    if mode == "Hold"   then return TRIGGER_STATE.active end
    return false
end

RunService.RenderStepped:Connect(function()
    if not triggerActive() then return end
    local target = triggerFindTarget()
    if target then
        triggerShoot()
    end
end)

