-- AIMBOT FUNCTIONS
-- ══════════════════════════════════════════════════════

local function updateDrawings()
    local viewport = Camera.ViewportSize
    local center   = Vector2.new(viewport.X * 0.5, viewport.Y * 0.5)
    local show     = CONFIG.SHOW_FOV  -- visible whenever Show FOV is on, regardless of aimbot state

    fovCircleOuter.Position    = center
    fovCircleInner.Position    = center
    fovCircleOuter.Radius      = CONFIG.FOV_RADIUS
    fovCircleInner.Radius      = CONFIG.FOV_RADIUS
    fovCircleInner.Color       = CONFIG.FOV_COLOR
    fovCircleOuter.Visible     = show
    fovCircleInner.Visible     = show
end

local function updateMyTeam()
    STATE.myTeamID = localPlayer:GetAttribute("TeamID")
end

local function getTargetTeamID(player)
    return player:GetAttribute("TeamID")
end

local function isEnemy(player)
    if not CONFIG.TEAM_CHECK then return true end
    if not STATE.myTeamID then return true end
    local targetTeamID = getTargetTeamID(player)
    if not targetTeamID then return true end
    return targetTeamID ~= STATE.myTeamID
end

-- Wall check ray params cache: built once per character, reused every frame
local wallCheckCache = {} -- player -> { params, char }

local function getWallParams(targetPlayer)
    local targetChar = targetPlayer.Character
    local lc = localPlayer.Character
    local cache = wallCheckCache[targetPlayer]

    -- Rebuild only if character changed
    if not cache or cache.char ~= targetChar or cache.localChar ~= lc then
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        -- Pass the Model objects directly — Roblox excludes all their descendants automatically
        local filter = {}
        if targetChar then filter[#filter+1] = targetChar end
        if lc then filter[#filter+1] = lc end
        params.FilterDescendantsInstances = filter
        wallCheckCache[targetPlayer] = { params=params, char=targetChar, localChar=lc }
        cache = wallCheckCache[targetPlayer]
    end
    return cache.params
end

local function isVisible(targetPlayer, targetPos)
    if not CONFIG.WALL_CHECK then return true end
    local origin = Camera.CFrame.Position
    local dir = targetPos - origin
    local dist = dir.Magnitude
    if dist < 0.5 then return true end
    local params = getWallParams(targetPlayer)
    local result = Workspace:Raycast(origin, dir * (1 / dist) * dist, params)
    return result == nil
end

local function getTargetPosition(character)
    if not character then return nil end
    if CONFIG.HITPART == "Head" then
        local h = character:FindFirstChild("Head")
        if h then return h.Position end
    elseif CONFIG.HITPART == "Torso" then
        local t = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
        if t then return t.Position end
    elseif CONFIG.HITPART == "Closest" then
        local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        local closestPart, closestDist = nil, math.huge
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") and (part.Name=="Head" or part.Name:find("Torso") or part.Name:find("Arm") or part.Name:find("Leg")) then
                local sp, on = Camera:WorldToViewportPoint(part.Position)
                if on then
                    local d = (Vector2.new(sp.X,sp.Y) - screenCenter).Magnitude
                    if d < closestDist then closestDist=d; closestPart=part end
                end
            end
        end
        if closestPart then return closestPart.Position end
    end
    local h = character:FindFirstChild("Head")
    if h then return h.Position end
    return nil
end

local function isTargetValid(player)
    if not player or player == localPlayer then return false end
    if not player.Character then return false end
    if not isEnemy(player) then return false end
    local hum = player.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return true
end

local function findTarget()
    local closest, closestDist = nil, math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, player in pairs(Players:GetPlayers()) do
        if isTargetValid(player) then
            local targetPos = getTargetPosition(player.Character)
            if targetPos then
                local distance = (Camera.CFrame.Position - targetPos).Magnitude
                if distance <= CONFIG.MAX_DISTANCE then
                    local sp = Camera:WorldToViewportPoint(targetPos)
                    if sp.Z > 0 then
                        local screenDist = (Vector2.new(sp.X,sp.Y) - screenCenter).Magnitude
                        if screenDist <= CONFIG.FOV_RADIUS * 1.5 and screenDist < closestDist then
                            -- Wall check last (most expensive, only run for candidates in FOV)
                            if isVisible(player, targetPos) then
                                closestDist = screenDist
                                closest = player
                            end
                        end
                    end
                end
            end
        end
    end

    return closest
end

local function applyStrongCameraRotation(targetPosition)
    local cameraPos = Camera.CFrame.Position
    local targetDirection = (targetPosition - cameraPos).Unit
    local smoothFactor = CONFIG.SMOOTHNESS / 100
    local alpha = CONFIG.SMOOTHNESS == 0 and 1 or math.clamp(0.05 + (1 - smoothFactor) * 0.95, 0.05, 1)

    local success, controller = pcall(function()
        return require(localPlayer.PlayerScripts.Controllers.CameraController)
    end)

    if success and controller then
        if controller.SetRotation then
            local lerpedCFrame = Camera.CFrame:Lerp(CFrame.lookAt(cameraPos, cameraPos + targetDirection), alpha)
            local x, y, _ = lerpedCFrame:ToEulerAnglesYXZ()
            controller:SetRotation(Vector2.new(x, y))
        elseif controller.ApplyRotationDelta then
            local currentLook = Camera.CFrame.LookVector
            local smoothedDirection = currentLook:Lerp(targetDirection, alpha)
            local axis = currentLook:Cross(smoothedDirection)
            if axis.Magnitude > 0 then
                local angle = math.acos(math.clamp(currentLook:Dot(smoothedDirection), -1, 1))
                local rotationCFrame = CFrame.fromAxisAngle(axis.Unit, angle)
                local _, y, x = rotationCFrame:ToEulerAnglesYXZ()
                controller:ApplyRotationDelta(Vector2.new(x, y) * alpha * 50)
            end
        end
    else
        if Camera.CameraType == Enum.CameraType.Scriptable then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(cameraPos, cameraPos + targetDirection), alpha)
        end
    end
end

local function clearTarget()
    STATE.target = nil
end

-- Target scan runs at ~20fps (every 3 heartbeat ticks) — finding a new target doesn't need 60fps
local _aimbotScanTick = 0
local _aimbotScanRate = 3

local function aimbotScanUpdate()
    _aimbotScanTick = _aimbotScanTick + 1
    if _aimbotScanTick < _aimbotScanRate then return end
    _aimbotScanTick = 0

    updateMyTeam()
    if not CONFIG.ENABLED or not STATE.active or not STATE.holding_key then
        if STATE.target then clearTarget() end
        return
    end

    -- Drop current target if invalid or behind wall
    if STATE.target then
        if not isTargetValid(STATE.target) then
            clearTarget()
        else
            local targetPos = getTargetPosition(STATE.target.Character)
            if targetPos and CONFIG.WALL_CHECK and not isVisible(STATE.target, targetPos) then
                clearTarget()
            end
        end
    end

    -- Scan for new target if needed
    if not STATE.target then
        STATE.target = findTarget()
    end
end

-- Camera rotation runs every RenderStepped for maximum smoothness
-- Anti-katana: suppresses lock while target is deflecting
local function lockOnUpdate()
    if not CONFIG.ENABLED or not STATE.active or not STATE.holding_key then return end
    if not STATE.target or not STATE.target.Character then return end

    -- Anti-katana: pause aim while target is deflecting
    if CONFIG.ANTI_KATANA and IsDeflecting(STATE.target) then return end

    local targetPos = getTargetPosition(STATE.target.Character)
    if targetPos then
        applyStrongCameraRotation(targetPos)
    end
end

