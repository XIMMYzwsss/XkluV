    hCorner.Parent = holder

    local hStroke = Instance.new("UIStroke")
    hStroke.Color = THEME.Accent
    hStroke.Thickness = 1
    hStroke.Transparency = 0.6
    hStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    hStroke.Parent = holder

    local info = Instance.new("TextLabel")
    info.Size = UDim2.new(1, -72, 1, 0)
    info.Position = UDim2.new(0, 8, 0, 0)
    info.BackgroundTransparency = 1
    info.TextXAlignment = Enum.TextXAlignment.Left
    info.TextYAlignment = Enum.TextYAlignment.Center
    info.TextColor3 = Color3.fromRGB(220, 220, 220)
    info.TextStrokeColor3 = Color3.new(0, 0, 0)
    info.TextStrokeTransparency = 0.5
    info.TextSize = 11
    info.Font = Enum.Font.Code
    info.TextWrapped = true
    info.Text = "Name: " .. sound.Name .. "\nID: " .. id .. "\nPath: " .. path
    info.ZIndex = 4
    info.Parent = holder

    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 56, 0, 26)
    copyBtn.Position = UDim2.new(1, -62, 0.5, -13)
    copyBtn.BackgroundColor3 = THEME.Accent
    copyBtn.BackgroundTransparency = 0.35
