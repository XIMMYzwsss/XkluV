        tabBtn.TextStrokeColor3 = Color3.new(0, 0, 0)
        tabBtn.TextStrokeTransparency = 0.5
        outerFrame.Visible = true
        self.currentTab = tab
    end)

    tab.button    = tabBtn
    tab.content   = content   -- default column (left for two-col, scroll for single)
