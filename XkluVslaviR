local function sfGetPath(obj)
    local path = obj.Name
    local parent = obj.Parent
    while parent and parent ~= game do
        path = parent.Name .. "." .. path
        parent = parent.Parent
    end
    return "game." .. path
end

local function sfCreateEntry(sound)
    if sfLogged[sound] then return end

    -- If at cap, remove the oldest entry
    if sfEntryCount >= SF_MAX_ENTRIES then
        for _, c in ipairs(sfScroll:GetChildren()) do
            if c:IsA("Frame") then
                c:Destroy()
                sfEntryCount = sfEntryCount - 1
                break
            end
        end
    end

    sfLogged[sound] = true
    sfEntryCount = sfEntryCount + 1

    local id   = tostring(sound.SoundId)
    local path = sfGetPath(sound)

    local holder = Instance.new("Frame")
    holder.Size = UDim2.new(1, -8, 0, 62)
    holder.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    holder.BackgroundTransparency = 0.35
    holder.BorderSizePixel = 0
    holder.ZIndex = 3
    holder.Parent = sfScroll

    local hCorner = Instance.new("UICorner")
