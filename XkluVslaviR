    dropdown.Position = UDim2.new(0.45, 0, 0.5, -12.5)
    dropdown.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    dropdown.Text = default .. "  ▼"
    dropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropdown.TextStrokeColor3 = Color3.new(0, 0, 0)
    dropdown.TextStrokeTransparency = 0.5
    dropdown.TextSize = 13
    dropdown.Font = Enum.Font.Gotham
    dropdown.BorderSizePixel = 0
    dropdown.ZIndex = 10
    dropdown.Parent = container

    local dropCorner = Instance.new("UICorner")
    dropCorner.CornerRadius = UDim.new(0, 5)
    dropCorner.Parent = dropdown

    local optGui = Instance.new("ScreenGui")
    optGui.Name = "DropdownOpts_" .. text
    optGui.ResetOnSpawn = false
    optGui.DisplayOrder = 200
    optGui.IgnoreGuiInset = true
    optGui.Parent = game:GetService("CoreGui")

    local optFrame = Instance.new("Frame")
    optFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 42)
    optFrame.BorderSizePixel = 0
    optFrame.Visible = false
    optFrame.ZIndex = 200
    optFrame.Parent = optGui

    local optFCorner = Instance.new("UICorner")
    optFCorner.CornerRadius = UDim.new(0, 5)
    optFCorner.Parent = optFrame

    local optLayout = Instance.new("UIListLayout")
    optLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optLayout.Parent = optFrame

    local currentValue = default
    local isOpen = false
    -- This flag is set to true when the mouse-down lands on an option button.
    -- The outside-click handler checks it so it doesn't close before the
    -- MouseButton1Click event fires on the option.
    local optionClickPending = false

    local function CloseDropdown()
        isOpen = false
        optionClickPending = false
        optFrame.Visible = false
        dropdown.Text = currentValue .. "  ▼"
    end

    local function OpenDropdown()
        isOpen = true
        local absPos  = dropdown.AbsolutePosition
        local absSize = dropdown.AbsoluteSize
        optFrame.Position = UDim2.fromOffset(absPos.X, absPos.Y + absSize.Y + 4)
        optFrame.Size = UDim2.fromOffset(absSize.X, #options * 30)
        optFrame.Visible = true
        dropdown.Text = currentValue .. "  ▲"
    end

    dropdown.MouseButton1Click:Connect(function()
        if isOpen then CloseDropdown() else OpenDropdown() end
    end)

    for _, option in ipairs(options) do
        local opt = option
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 30)
        optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 42)
        optBtn.Text = opt
        optBtn.TextColor3 = Color3.fromRGB(210, 210, 210)
    optBtn.TextStrokeColor3 = Color3.new(0, 0, 0)
    optBtn.TextStrokeTransparency = 0.5
        optBtn.TextSize = 13
        optBtn.Font = Enum.Font.Gotham
        optBtn.BorderSizePixel = 0
        optBtn.ZIndex = 201
        optBtn.Parent = optFrame

        optBtn.MouseEnter:Connect(function() optBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 65) end)
        optBtn.MouseLeave:Connect(function() optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 42) end)

        -- Set the pending flag on mouse DOWN (InputBegan) so the outside-close
        -- handler sees it in the same event cycle and skips closing.
        optBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                optionClickPending = true
            end
        end)

        -- Actually commit the selection on the full click (up+down on same element)
        optBtn.MouseButton1Click:Connect(function()
            currentValue = opt
            dropdown.Text = opt .. "  ▼"
            callback(opt)
            CloseDropdown()
        end)
    end

    -- Close when clicking outside — only if the click didn't land on an option button
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
            -- If an option button already claimed this click, let its Click handler run
            if optionClickPending then return end

            local mp = UserInputService:GetMouseLocation()
            local dp = dropdown.AbsolutePosition
            local ds = dropdown.AbsoluteSize
            local op = optFrame.AbsolutePosition
            local os = optFrame.AbsoluteSize

            local inDD = mp.X >= dp.X and mp.X <= dp.X+ds.X and mp.Y >= dp.Y and mp.Y <= dp.Y+ds.Y
            local inOF = mp.X >= op.X and mp.X <= op.X+os.X and mp.Y >= op.Y and mp.Y <= op.Y+os.Y

            if not inDD and not inOF then
                CloseDropdown()
            end
        end
    end)

    return {
        GetValue = function() return currentValue end,
        Destroy  = function() optGui:Destroy() end,
    }
end

