local function RemoveESP(player)
    local esp = ESPObjects[player]
    if not esp then return end
    for _, l in ipairs(esp.BoxLines) do l:Remove() end
    for _, l in ipairs(esp.BoxOutlines) do l:Remove() end
    for _, l in ipairs(esp.SkeletonLines) do l:Remove() end
    for _, l in ipairs(esp.SkeletonOutlines) do l:Remove() end
    for _, l in ipairs(esp.HeadCircle) do l:Remove() end
    for _, l in ipairs(esp.HeadCircleOutline) do l:Remove() end
    esp.NameLabel:Destroy()
    esp.DistLabel:Destroy()
    esp.FacingLabel:Destroy()
    esp.DeflectLabel:Destroy()
    ESPObjects[player] = nil
    ClearPartCache(player)
end

