    svWhiteLayer.Size = UDim2.new(1, 0, 1, 0)
    svWhiteLayer.BackgroundColor3 = Color3.new(1, 1, 1)
    svWhiteLayer.BorderSizePixel = 0
    svWhiteLayer.ZIndex = 303
    svWhiteLayer.Parent = svFrame
